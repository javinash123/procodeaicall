NODE_ENV=production
PORT=5000

# MongoDB connection string (required)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Session secret - use a long random string (required)
SESSION_SECRET=replace-this-with-a-very-long-random-secret-string

# OpenAI API key for AI script generation and TTS (required)
OPENAI_API_KEY=sk-...

# Razorpay keys (if using payments)
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=...

# Exotel credentials (if using Exotel voicebot)
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_SID=
